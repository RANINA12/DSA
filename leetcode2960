class Solution {
    public int countTestedDevices(int[] b) {
        int m = b.length ;
        int op = 0;
        for(int i = 0 ; i<m ; i++){
            if(b[i]>0) {
                op++;
                for(int j =i+1 ; j<m ; j++){
                    b[j]--;
                }
        }
        }
        return op;
    }
}
