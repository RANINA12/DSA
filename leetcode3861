class Solution {
    public int minimumIndex(int[] capacity, int itemSize) {
        int ans = Integer.MAX_VALUE;
        int a = -1;
        for(int i = 0 ; i<capacity.length ; i++){
            if(capacity[i]>=itemSize){
                if(ans > capacity[i]){
                    ans = capacity[i];
                    a=i;
                }
            }
        }
        return a ;
    }
}
