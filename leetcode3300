class Solution {
    public int solve(int num){
      int sum = 0;
      while(num!=0){
        sum = sum + num%10 ;
        num = num/10;
      }
      return sum ;
    }
    public int minElement(int[] nums) {
        int min = Integer.MAX_VALUE ;
        for(int i = 0 ; i<nums.length ; i++){
            min = Math.min(min , solve(nums[i]));
        }
        return min ;
    }
}
