class Solution {
    public int firstMatchingIndex(String s) {
        int n = s.length();
        int min = 101;
        for(int i =0 ;i<s.length();i++){
            if(s.charAt(i)==s.charAt(n-i-1)){
                min = Math.min(min , i);
            }
        }

        return min==101 ? -1 : min;
    }
}
