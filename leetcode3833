class Solution {
    public int dominantIndices(int[] nums) {
        int sum = 0;
        int count=0;
        for(int i = 0 ; i<nums.length ; i++){
            sum=sum+nums[i];
        }
        for(int i = 0; i<nums.length-1 ; i++){
            int avg = (sum-nums[i]) / (nums.length-(i+1)) ;
            sum =sum - nums[i];
            if(nums[i]>avg) count++;
        }
        return count;
    }
}
