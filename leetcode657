class Solution {
    public boolean judgeCircle(String moves) {
        int up = 0;
        int left = 0;
        int n = moves.length();
        for (int i = 0; i < n ; i++) {
            char ch = moves.charAt(i);
            if (ch == 'U')
                up++;
            else if (ch == 'D')
                up--;
            else if (ch == 'L')
                left++;
            else
                left--;
        }
        return up==0 && left==0;
    }
}
