class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int countR = 0;
        int countD = 0;
        int countL=0;

        for(int i = 0 ;i<moves.length();i++){
            if(moves.charAt(i)=='R') countR++;
            else if(moves.charAt(i)=='L') countL++;
            else countD++;
        }
        int a=0;

         if(countR>countL) a=countR+countD-countL;
         else  a= countL+countD-countR;
         return a;
    }
}
