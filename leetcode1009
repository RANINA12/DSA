class Solution {
    public int bitwiseComplement(int n) {
        String s = Integer.toBinaryString(n);
        StringBuilder s1 = new StringBuilder();
        for(int i = 0 ; i<s.length() ; i++){
            if(s.charAt(i)=='1') s1.append('0');
            else s1.append('1');
        }

        int a = Integer.parseInt(s1.toString(), 2);
        return a;
    }
}
